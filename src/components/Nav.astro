---
import SocialIcons from './SocialIcons.astro';

const base = import.meta.env.BASE_URL;
const navLinks = [
  { href: `${base}work`, label: 'Darbai' },
  { href: `${base}services`, label: 'Paslaugos' },
  { href: `${base}about`, label: 'Apie' },
  { href: `${base}press`, label: 'Spauda' },
  { href: `${base}contact`, label: 'Susisiekti' },
];

const currentPath = Astro.url.pathname;
---

<header class="fixed top-0 left-0 right-0 z-50 bg-white/90 backdrop-blur-sm border-b border-rose-100">
  <nav class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
    <a href={base} class="font-signature text-3xl text-neutral-900 hover:text-rose-400 transition-colors leading-none">
      Deimantė Šuliauskaitė
    </a>

    <!-- Desktop nav -->
    <div class="hidden sm:flex items-center gap-8">
      <ul class="flex items-center gap-8">
        {navLinks.map(link => (
          <li>
            <a
              href={link.href}
              class={`text-sm tracking-wide transition-colors hover:text-rose-400 ${
                currentPath.startsWith(link.href) ? 'text-rose-500 font-medium' : 'text-neutral-600'
              }`}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
      <SocialIcons iconClass="w-[18px] h-[18px]" />
    </div>

    <!-- Mobile menu button -->
    <button
      id="menu-toggle"
      type="button"
      aria-label="Atidaryti meniu"
      aria-expanded="false"
      class="sm:hidden relative w-8 h-8 flex flex-col items-center justify-center gap-1.5"
    >
      <span class="menu-bar block w-6 h-px bg-neutral-900 transition-transform"></span>
      <span class="menu-bar block w-6 h-px bg-neutral-900 transition-transform"></span>
    </button>
  </nav>

  <!-- Mobile menu panel -->
  <div id="mobile-menu" class="sm:hidden hidden flex-col border-t border-rose-100 bg-white px-6 py-4 gap-1">
    <ul class="flex flex-col gap-1">
      {navLinks.map(link => (
        <li>
          <a
            href={link.href}
            class={`block py-3 text-base tracking-wide transition-colors ${
              currentPath.startsWith(link.href) ? 'text-rose-500 font-medium' : 'text-neutral-600'
            }`}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
    <SocialIcons class="pt-3 mt-2 border-t border-rose-100" iconClass="w-5 h-5" />
  </div>
</header>
<div class="h-16"></div>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');

  toggle?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden');
    toggle.setAttribute('aria-expanded', String(!isOpen));
    toggle.classList.toggle('is-open');
  });
</script>

<style>
  #menu-toggle.is-open .menu-bar:first-child {
    transform: translateY(3px) rotate(45deg);
  }
  #menu-toggle.is-open .menu-bar:last-child {
    transform: translateY(-3px) rotate(-45deg);
  }
  #mobile-menu:not(.hidden) {
    display: flex;
  }
</style>
