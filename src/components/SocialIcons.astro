---
interface Props {
  class?: string;
  iconClass?: string;
}

const { class: className = '', iconClass = 'w-5 h-5' } = Astro.props;
---

<div class={`flex items-center gap-4 ${className}`}>
  <a
    href="https://www.instagram.com/ataik_nutrauksiu/"
    target="_blank"
    rel="noopener"
    aria-label="Instagram"
    class="text-neutral-600 hover:text-neutral-900 transition-colors"
  >
    <svg class={iconClass} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
      <rect x="3" y="3" width="18" height="18" rx="5" />
      <circle cx="12" cy="12" r="4" />
      <circle cx="17.2" cy="6.8" r="1.1" fill="currentColor" stroke="none" />
    </svg>
  </a>
  <a
    href="https://www.facebook.com/fotodiamo"
    target="_blank"
    rel="noopener"
    aria-label="Facebook"
    class="text-neutral-600 hover:text-neutral-900 transition-colors"
  >
    <svg class={iconClass} viewBox="0 0 24 24" fill="currentColor">
      <path d="M22 12.06C22 6.5 17.52 2 12 2S2 6.5 2 12.06c0 5 3.66 9.15 8.44 9.94v-7.03H7.9v-2.91h2.54V9.85c0-2.5 1.49-3.89 3.78-3.89 1.1 0 2.24.2 2.24.2v2.46h-1.26c-1.24 0-1.63.77-1.63 1.56v1.87h2.78l-.44 2.91h-2.34V22c4.78-.79 8.44-4.94 8.44-9.94z" />
    </svg>
  </a>
</div>
