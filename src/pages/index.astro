---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Deimantė Šuliauskaitė" description="Fotografijos portfolio — akimirkos, kurios išlieka.">
  <!-- Hero -->
  <section class="relative h-[90vh] bg-neutral-100 flex items-end">
    <img src={`${import.meta.env.BASE_URL}images/photo_3.webp`} alt="" class="absolute inset-0 w-full h-full object-cover" />
    <div class="absolute inset-0 bg-black/20"></div>
    <div class="relative z-10 p-10 sm:p-16">
      <h1 class="font-serif text-white text-5xl sm:text-7xl italic font-medium tracking-tight drop-shadow-lg">
        Deimantė Šuliauskaitė
      </h1>
      <p class="text-white/80 mt-3 text-lg sm:text-xl font-light tracking-wide drop-shadow">
        Dokumentinė ir portretinė fotografija
      </p>
    </div>
  </section>

  <!-- Intro -->
  <section class="max-w-2xl mx-auto px-6 py-24 text-center">
    <p class="font-serif text-2xl sm:text-3xl italic leading-relaxed text-neutral-700">
      23 metų fotografė iš Bartininkų. Fotografuoju žmones, akimirkas ir nuotaikas — ieškau tylos tarp kadrų ir to, kas nepasakoma žodžiais.
    </p>
    <a href={`${import.meta.env.BASE_URL}work`} class="inline-block mt-10 text-sm tracking-widest uppercase border-b border-neutral-900 pb-1 hover:text-rose-500 hover:border-rose-400 transition-colors">
      Žiūrėti darbus
    </a>
  </section>

  <!-- Featured images preview -->
  <section class="max-w-6xl mx-auto px-6 pb-24">
    <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
      {['photo_4', 'photo_5', 'photo_6', 'photo_7', 'photo_8', 'photo_9'].map(photo => (
        <div class="aspect-square bg-rose-50 overflow-hidden">
          <img src={`${import.meta.env.BASE_URL}images/${photo}.webp`} alt="" class="w-full h-full object-cover hover:scale-105 transition-transform duration-300" />
        </div>
      ))}
    </div>
    <div class="text-center mt-10">
      <a href={`${import.meta.env.BASE_URL}work`} class="text-sm tracking-widest uppercase border-b border-neutral-900 pb-1 hover:text-rose-500 hover:border-rose-400 transition-colors">
        Visi darbai
      </a>
    </div>
  </section>
</Layout>
