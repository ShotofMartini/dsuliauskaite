---
import Layout from '../layouts/Layout.astro';
import Photo from '../components/Photo.astro';
import { hasSanity, getTestimonials, getSiteSettings } from '../lib/sanity';

// Šabloniniai atsiliepimai — rodomi, kol Sanity nesukonfigūruotas arba neturi įrašų
const placeholderTestimonials = [
  {
    text: 'Deimantė sugebėjo užfiksuoti tokias nuoširdžias akimirkas, kokių net nesitikėjome. Nuotraukos pranoko visus lūkesčius!',
    author: 'Gabrielė',
    occasion: 'Šeimos fotosesija',
  },
  {
    text: 'Fotosesijos metu jaučiausi visiškai laisvai. Rezultatas — gyvos, natūralios nuotraukos, kurias mylime iki šiol.',
    author: 'Tomas',
    occasion: 'Asmeninė sesija',
  },
  {
    text: 'Profesionalu, jauku ir su didele meile detalėms. Tikrai rekomenduoju ir kreipsiuosi dar ne kartą.',
    author: 'Rūta',
    occasion: 'Renginio fotografija',
  },
];

const sanitySettings = hasSanity ? await getSiteSettings() : null;
const sanityTestimonials = hasSanity ? await getTestimonials() : null;

const testimonials = sanityTestimonials && sanityTestimonials.length > 0 ? sanityTestimonials : placeholderTestimonials;
const heroPhoto = sanitySettings?.heroPhoto ?? 'nature_dew_leaves_1';
const introText =
  sanitySettings?.introText ??
  '23 metų fotografė iš Bartninkų. Fotografuoju žmones, akimirkas ir nuotaikas — ieškau tylos tarp kadrų ir to, kas nepasakoma žodžiais.';
const featuredPhotos = ['portrait_blossom_kiss', 'nature_field_flowers', 'concept_red_fabric_hands', 'portrait_autumn_leaves', 'nature_mushroom', 'concept_thread_mask_forest'];
---

<Layout title="Deimantė Šuliauskaitė" description="Fotografijos portfolio — akimirkos, kurios išlieka.">
  <!-- Hero -->
  <section class="relative h-[90vh] bg-neutral-100 flex items-end">
    <Photo photo={heroPhoto} class="absolute inset-0 w-full h-full object-cover" widths={[640, 1024, 1600, 2400]} sizes="100vw" />
    <div class="absolute inset-0 bg-black/20"></div>
    <div class="relative z-10 p-10 sm:p-16">
      <h1 class="font-serif text-white text-5xl sm:text-7xl italic font-medium tracking-tight drop-shadow-lg">
        Deimantė Šuliauskaitė
      </h1>
      <p class="text-white/80 mt-3 text-lg sm:text-xl font-light tracking-wide drop-shadow">
        Dokumentinė ir portretinė fotografija
      </p>
    </div>
  </section>

  <!-- Intro -->
  <section class="max-w-2xl mx-auto px-6 py-24 text-center">
    <p class="font-serif text-2xl sm:text-3xl italic leading-relaxed text-neutral-700">
      {introText}
    </p>
    <a href={`${import.meta.env.BASE_URL}work`} class="inline-block mt-10 text-sm tracking-widest uppercase border-b border-neutral-900 pb-1 hover:text-rose-500 hover:border-rose-400 transition-colors">
      Žiūrėti darbus
    </a>
  </section>

  <!-- Featured images preview -->
  <section class="max-w-6xl mx-auto px-6 pb-24">
    <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
      {featuredPhotos.map(photo => (
        <div class="aspect-square bg-rose-50 overflow-hidden">
          <Photo photo={photo} class="w-full h-full object-cover hover:scale-105 transition-transform duration-300" widths={[300, 500, 800]} sizes="(min-width: 640px) 33vw, 50vw" />
        </div>
      ))}
    </div>
    <div class="text-center mt-10">
      <a href={`${import.meta.env.BASE_URL}work`} class="text-sm tracking-widest uppercase border-b border-neutral-900 pb-1 hover:text-rose-500 hover:border-rose-400 transition-colors">
        Visi darbai
      </a>
    </div>
  </section>

  <!-- Atsiliepimai -->
  <section class="max-w-5xl mx-auto px-6 py-20">
    <h2 class="font-serif text-4xl italic font-medium tracking-tight text-center mb-16">Klientų atsiliepimai</h2>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-10">
      {testimonials.map(t => (
        <figure class="text-center">
          <span class="font-serif text-5xl italic text-rose-200 leading-none">&ldquo;</span>
          <blockquote class="text-neutral-700 leading-relaxed mt-2 mb-6">{t.text}</blockquote>
          <figcaption class="text-sm">
            <span class="font-medium text-neutral-900">{t.author}</span>
            {t.occasion && <span class="block text-neutral-400 mt-1">{t.occasion}</span>}
            {'sourceUrl' in t && t.sourceUrl && (
              <a href={t.sourceUrl} target="_blank" rel="noopener" class="block text-rose-400 hover:text-rose-500 mt-1 text-xs">Facebook ↗</a>
            )}
          </figcaption>
        </figure>
      ))}
    </div>
  </section>

  <!-- Greitos nuorodos -->
  <section class="bg-rose-50/60 py-20">
    <div class="max-w-4xl mx-auto px-6 grid grid-cols-1 sm:grid-cols-3 gap-10 text-center">
      <div>
        <h2 class="font-serif text-2xl italic font-medium mb-3">Paslaugos</h2>
        <p class="text-neutral-600 text-sm leading-relaxed mb-4">Portretai, šeimos sesijos, renginiai ir bendradarbiavimai.</p>
        <a href={`${import.meta.env.BASE_URL}services`} class="text-sm tracking-wide border-b border-neutral-400 pb-0.5 hover:text-rose-500 hover:border-rose-400 transition-colors">Sužinoti daugiau</a>
      </div>
      <div>
        <h2 class="font-serif text-2xl italic font-medium mb-3">Kaip vyksta</h2>
        <p class="text-neutral-600 text-sm leading-relaxed mb-4">Nuo pirmos žinutės iki paruoštų nuotraukų — žingsnis po žingsnio.</p>
        <a href={`${import.meta.env.BASE_URL}services`} class="text-sm tracking-wide border-b border-neutral-400 pb-0.5 hover:text-rose-500 hover:border-rose-400 transition-colors">Fotosesijos eiga</a>
      </div>
      <div>
        <h2 class="font-serif text-2xl italic font-medium mb-3">Dažni klausimai</h2>
        <p class="text-neutral-600 text-sm leading-relaxed mb-4">Atsakymai į dažniausiai užduodamus klausimus apie fotosesijas.</p>
        <a href={`${import.meta.env.BASE_URL}services#duk`} class="text-sm tracking-wide border-b border-neutral-400 pb-0.5 hover:text-rose-500 hover:border-rose-400 transition-colors">Skaityti DUK</a>
      </div>
    </div>
  </section>
</Layout>
