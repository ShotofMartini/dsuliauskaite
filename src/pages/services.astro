---
import Layout from '../layouts/Layout.astro';
import { hasSanity, getFaqItems } from '../lib/sanity';

const base = import.meta.env.BASE_URL;

const services = [
  {
    title: 'Portretai',
    description: 'Asmeninės fotosesijos, kuriose svarbiausia — tu pats. Natūralus žvilgsnis, tikra nuotaika, be perteklinės pozos.',
  },
  {
    title: 'Šeimos fotosesijos',
    description: 'Šiltos, autentiškos akimirkos su artimiausiais žmonėmis — tokios, kurias norėsis prisiminti po daugelio metų.',
  },
  {
    title: 'Renginiai ir šventės',
    description: 'Gimtadieniai, sutikimai, šeimos švenčių akimirkos — papasakotos nuotraukomis, nepertraukiant pačios šventės eigos.',
  },
  {
    title: 'Meninės ir koncepcinės sesijos',
    description: 'Idėjomis grįstos fotosesijos, kuriose kartu ieškome unikalios, tau tinkančios vizualinės kalbos.',
  },
  {
    title: 'Bendradarbiavimas su prekės ženklais',
    description: 'Produktų ir lifestyle fotografija bendradarbiavimams, kampanijoms ir socialiniams tinklams.',
  },
];

const steps = [
  {
    title: 'Susisiekimas',
    description: 'Parašyk man el. paštu arba per socialinius tinklus — papasakok, kokios fotosesijos ieškai ir kokia proga.',
  },
  {
    title: 'Idėjos aptarimas',
    description: 'Kartu suderiname datą, vietą ir nuotaiką. Atsakau į visus klausimus ir padedu pasiruošti.',
  },
  {
    title: 'Fotosesija',
    description: 'Sesijos metu jautiesi laisvai — padedu pozuoti, bet svarbiausia išlieka tikros, natūralios emocijos.',
  },
  {
    title: 'Nuotraukų gavimas',
    description: 'Atrenku ir apdoroju geriausius kadrus. Paruoštas nuotraukas gauni per 1–4 savaites. Pristatomos tik apdorotos nuotraukos — neretušuoti (RAW) originalai neteikiami.',
  },
];

const placeholderFaqs = [
  {
    question: 'Ar atvažiuoji fotografuoti į kitą miestą?',
    answer: 'Taip, fotografuoju įvairiose Lietuvos vietose. Kelionės sąlygas aptariame individualiai, atsižvelgiant į atstumą.',
  },
  {
    question: 'Per kiek laiko gaunu nuotraukas?',
    answer: 'Paruoštas nuotraukas pristatau per 1–4 savaites — terminas priklauso nuo sesijos apimties ir sezono.',
  },
  {
    question: 'Ar nuotraukos apdorojamos?',
    answer: 'Taip, kiekvieną atrinktą nuotrauką apdoroju (spalvos, šviesa, subtilus retušas), išlaikydama natūralų ir gyvą rezultatą.',
  },
  {
    question: 'Kiek nuotraukų gausiu?',
    answer: 'Nuotraukų skaičius priklauso nuo sesijos tipo ir trukmės — tikslų skaičių aptariame prieš fotosesiją.',
  },
  {
    question: 'Ar gausiu neapdorotas (RAW) nuotraukas?',
    answer: 'Ne — pristatau tik atrinktas ir apdorotas nuotraukas. Neretušuoti (RAW) originalai klientams neteikiami, nes apdorojimas yra neatsiejama mano darbo ir stiliaus dalis.',
  },
  {
    question: 'Kaip užsisakyti fotosesiją?',
    answer: 'Parašyk man el. paštu arba per Instagram / Facebook. Suderinsime datą ir visas detales.',
  },
];

const sanityFaqs = hasSanity ? await getFaqItems() : null;
const faqs = sanityFaqs && sanityFaqs.length > 0 ? sanityFaqs : placeholderFaqs;
---

<Layout title="Paslaugos — Deimantė Šuliauskaitė" description="Fotografijos paslaugos — portretai, šeimos sesijos, renginiai ir bendradarbiavimai.">
  <section class="max-w-4xl mx-auto px-6 py-16">
    <h1 class="font-serif text-5xl italic font-medium tracking-tight mb-8">Paslaugos</h1>

    <p class="text-neutral-700 leading-relaxed max-w-2xl mb-16">
      Fotografuoju įvairias progas ir nuotaikas — nuo asmeninių portretų iki gyvų renginio akimirkų. Kiekviena sesija pritaikoma individualiai, pagal tavo norus ir istoriją, kurią norisi papasakoti.
    </p>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-10">
      {services.map(service => (
        <div class="border-l-2 border-rose-200 pl-6">
          <h2 class="font-serif text-2xl italic font-medium mb-2">{service.title}</h2>
          <p class="text-neutral-600 text-sm leading-relaxed">{service.description}</p>
        </div>
      ))}
    </div>

    <!-- Fotosesijos eiga -->
    <div class="mt-24">
      <h2 class="font-serif text-4xl italic font-medium tracking-tight mb-12">Kaip vyksta fotosesija</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
        {steps.map((step, i) => (
          <div>
            <span class="font-serif text-3xl italic text-rose-300">0{i + 1}</span>
            <h3 class="text-base font-medium mt-3 mb-2">{step.title}</h3>
            <p class="text-neutral-600 text-sm leading-relaxed">{step.description}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- DUK -->
    <div id="duk" class="mt-24 scroll-mt-24">
      <h2 class="font-serif text-4xl italic font-medium tracking-tight mb-12">Dažni klausimai</h2>
      <div class="divide-y divide-neutral-200 border-t border-neutral-200">
        {faqs.map(faq => (
          <details class="group py-5">
            <summary class="flex justify-between items-center cursor-pointer list-none text-base font-medium hover:text-rose-500 transition-colors">
              {faq.question}
              <span class="ml-4 text-rose-300 text-xl transition-transform group-open:rotate-45">+</span>
            </summary>
            <p class="text-neutral-600 text-sm leading-relaxed mt-3">{faq.answer}</p>
          </details>
        ))}
      </div>
    </div>

    <div class="mt-24 pt-10 border-t border-rose-100 text-center">
      <p class="text-neutral-600 mb-6">
        Kaina priklauso nuo sesijos trukmės, vietos ir pobūdžio — aptariame individualiai.
      </p>
      <a
        href={`${base}contact`}
        class="inline-block text-sm tracking-widest uppercase border-b border-neutral-900 pb-1 hover:text-rose-500 hover:border-rose-400 transition-colors"
      >
        Susisiekti dėl kainos
      </a>
    </div>
  </section>
</Layout>
