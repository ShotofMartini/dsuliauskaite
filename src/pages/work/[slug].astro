---
import Layout from '../../layouts/Layout.astro';
import { series } from '../../data/series';

export function getStaticPaths() {
  return series.map((s) => ({ params: { slug: s.slug }, props: { series: s } }));
}

const { series: s } = Astro.props;
---

<Layout title={`${s.title} — Deimantė Šuliauskaitė`} description={`${s.title} — fotografijų serija.`}>
  <section class="max-w-6xl mx-auto px-6 py-16">
    <a href="/work" class="text-sm text-neutral-500 hover:text-neutral-900 transition-colors">&larr; Visi darbai</a>
    <h1 class="text-3xl font-light tracking-tight mt-4 mb-16">{s.title}</h1>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
      {s.photos.map((photo: string) => (
        <div class="aspect-[4/3] bg-neutral-100 overflow-hidden">
          <img src={`/images/${photo}.webp`} alt="" class="w-full h-full object-cover" />
        </div>
      ))}
    </div>
  </section>
</Layout>
