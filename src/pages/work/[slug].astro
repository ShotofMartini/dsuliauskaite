---
import Layout from '../../layouts/Layout.astro';
import Photo from '../../components/Photo.astro';
import { series as localSeries } from '../../data/series';
import { hasSanity, getSeries } from '../../lib/sanity';

export async function getStaticPaths() {
  const sanitySeries = hasSanity ? await getSeries() : null;
  const series = sanitySeries
    ? sanitySeries.map((s) => ({ title: s.title, slug: s.slug.current, photos: s.photos }))
    : localSeries;

  return series.map((s) => ({ params: { slug: s.slug }, props: { series: s } }));
}

const { series: s } = Astro.props;
---

<Layout title={`${s.title} — Deimantė Šuliauskaitė`} description={`${s.title} — fotografijų serija.`}>
  <section class="max-w-6xl mx-auto px-6 py-16">
    <a href={`${import.meta.env.BASE_URL}work`} class="text-sm text-neutral-500 hover:text-rose-500 transition-colors">&larr; Visi darbai</a>
    <h1 class="font-serif text-5xl italic font-medium tracking-tight mt-4 mb-16">{s.title}</h1>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
      {s.photos.map((photo) => (
        <div class="aspect-[4/3] bg-rose-50 overflow-hidden">
          <Photo photo={photo} class="w-full h-full object-cover" widths={[400, 700, 1100]} sizes="(min-width: 640px) 50vw, 100vw" />
        </div>
      ))}
    </div>
  </section>
</Layout>
