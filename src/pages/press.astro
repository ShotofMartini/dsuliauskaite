---
import Layout from '../layouts/Layout.astro';
import { hasSanity, getPressItems } from '../lib/sanity';

const placeholderPublications = [
  {
    outlet: '15min.lt',
    title: 'Pavyzdinis straipsnio pavadinimas apie fotografės darbus',
    date: '2024-11-01',
    url: '#',
  },
  {
    outlet: 'Delfi',
    title: 'Kitas pavyzdinis publikacijos pavadinimas',
    date: '2024-08-15',
    url: '#',
  },
  {
    outlet: 'Lietuvos Rytas',
    title: 'Pavyzdinis straipsnio pavadinimas',
    date: '2024-05-20',
    url: '#',
  },
];

const sanityPress = hasSanity ? await getPressItems() : null;
const publications = sanityPress && sanityPress.length > 0 ? sanityPress : placeholderPublications;

function formatDate(dateStr: string) {
  return new Date(dateStr).toLocaleDateString('lt-LT', { year: 'numeric', month: 'long' });
}
---

<Layout title="Spauda — Deimantė Šuliauskaitė" description="Spauda ir publikacijos apie fotografės darbus.">
  <section class="max-w-3xl mx-auto px-6 py-16">
    <h1 class="font-serif text-5xl italic font-medium tracking-tight mb-16">Spauda</h1>

    <ul class="divide-y divide-neutral-200">
      {publications.map(pub => (
        <li class="py-8">
          <a href={pub.url} target="_blank" rel="noopener" class="group flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-2">
            <div>
              <span class="text-xs tracking-widest uppercase text-rose-400">{pub.outlet}</span>
              <p class="mt-1 text-base font-medium group-hover:text-rose-500 transition-colors">{pub.title}</p>
            </div>
            <span class="text-sm text-neutral-400 whitespace-nowrap">{formatDate(pub.date)}</span>
          </a>
        </li>
      ))}
    </ul>
  </section>
</Layout>
