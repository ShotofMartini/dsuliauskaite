---
import Layout from '../layouts/Layout.astro';

// Web3Forms prieigos raktas — pakeisti tikru raktu iš https://web3forms.com
const WEB3FORMS_ACCESS_KEY = 'YOUR_ACCESS_KEY_HERE';
---

<Layout title="Susisiekti — Deimantė Šuliauskaitė" description="Susisiekite dėl bendradarbiavimo, fotosesijų ar kitų klausimų.">
  <section class="max-w-xl mx-auto px-6 py-16">
    <h1 class="font-serif text-5xl italic font-medium tracking-tight mb-16">Susisiekti</h1>

    <div class="space-y-12">
      <div>
        <p class="text-neutral-700 leading-relaxed">
          Laukiu pasiūlymų dėl fotosesijų, bendradarbiavimo ir kitų idėjų. Rašykite, jei turite klausimų arba tiesiog norite pasisveikinti.
        </p>
      </div>

      <!-- Kontaktinė forma -->
      <form id="contact-form" action="https://api.web3forms.com/submit" method="POST" class="space-y-5">
        <input type="hidden" name="access_key" value={WEB3FORMS_ACCESS_KEY} />
        <input type="hidden" name="subject" value="Nauja žinutė iš svetainės" />
        <input type="hidden" name="from_name" value="Deimantės svetainė" />
        <!-- Apsauga nuo šlamšto (honeypot) -->
        <input type="checkbox" name="botcheck" class="hidden" style="display:none" tabindex="-1" autocomplete="off" />

        <div>
          <label for="name" class="block text-xs tracking-wide uppercase text-neutral-400 mb-2">Vardas</label>
          <input type="text" id="name" name="name" required class="w-full border border-neutral-300 px-4 py-3 text-sm focus:outline-none focus:border-rose-400 transition-colors" />
        </div>

        <div>
          <label for="email" class="block text-xs tracking-wide uppercase text-neutral-400 mb-2">El. paštas</label>
          <input type="email" id="email" name="email" required class="w-full border border-neutral-300 px-4 py-3 text-sm focus:outline-none focus:border-rose-400 transition-colors" />
        </div>

        <div>
          <label for="message" class="block text-xs tracking-wide uppercase text-neutral-400 mb-2">Žinutė</label>
          <textarea id="message" name="message" rows="5" required class="w-full border border-neutral-300 px-4 py-3 text-sm focus:outline-none focus:border-rose-400 transition-colors resize-none"></textarea>
        </div>

        <button type="submit" class="text-sm tracking-widest uppercase border border-neutral-900 px-8 py-3 hover:bg-rose-400 hover:border-rose-400 hover:text-white transition-colors">
          Siųsti žinutę
        </button>

        <p id="form-result" class="text-sm hidden"></p>
      </form>

      <!-- Tiesioginiai kontaktai -->
      <div class="space-y-4 text-sm pt-4 border-t border-rose-100">
        <div class="flex items-center gap-4">
          <span class="w-24 text-neutral-400 tracking-wide uppercase text-xs">El. paštas</span>
          <a href="mailto:dsuliauskaite@gmail.com" class="border-b border-neutral-400 pb-0.5 hover:text-rose-500 transition-colors">
            dsuliauskaite@gmail.com
          </a>
        </div>
        <div class="flex items-center gap-4">
          <span class="w-24 text-neutral-400 tracking-wide uppercase text-xs">Instagram</span>
          <a href="https://www.instagram.com/ataik_nutrauksiu/" target="_blank" rel="noopener" class="border-b border-neutral-400 pb-0.5 hover:text-rose-500 transition-colors">
            @ataik_nutrauksiu
          </a>
        </div>
        <div class="flex items-center gap-4">
          <span class="w-24 text-neutral-400 tracking-wide uppercase text-xs">Facebook</span>
          <a href="https://www.facebook.com/fotodiamo" target="_blank" rel="noopener" class="border-b border-neutral-400 pb-0.5 hover:text-rose-500 transition-colors">
            fotodiamo
          </a>
        </div>
      </div>
    </div>
  </section>

  <script>
    const form = document.getElementById('contact-form') as HTMLFormElement | null;
    const result = document.getElementById('form-result');

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!result) return;

      const formData = new FormData(form);
      result.classList.remove('hidden', 'text-rose-500', 'text-green-600');
      result.textContent = 'Siunčiama…';

      try {
        const response = await fetch('https://api.web3forms.com/submit', {
          method: 'POST',
          body: formData,
        });
        const data = await response.json();

        if (data.success) {
          result.textContent = 'Ačiū! Žinutė išsiųsta — netrukus susisieksiu.';
          result.classList.add('text-green-600');
          form.reset();
        } else {
          result.textContent = 'Nepavyko išsiųsti. Bandykite dar kartą arba rašykite el. paštu.';
          result.classList.add('text-rose-500');
        }
      } catch {
        result.textContent = 'Nepavyko išsiųsti. Bandykite dar kartą arba rašykite el. paštu.';
        result.classList.add('text-rose-500');
      }
    });
  </script>
</Layout>
