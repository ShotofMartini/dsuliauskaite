---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Susisiekti — Deimantė Šuliauskaitė" description="Susisiekite dėl bendradarbiavimo, fotosesijų ar kitų klausimų.">
  <section class="max-w-xl mx-auto px-6 py-16">
    <h1 class="text-3xl font-light tracking-tight mb-16">Susisiekti</h1>

    <div class="space-y-10">
      <div>
        <p class="text-neutral-700 leading-relaxed">
          Laukiu pasiūlymų dėl fotosesijų, bendradarbiavimo ir kitų idėjų. Rašykite, jei turite klausimų arba tiesiog norite pasisveikinti.
        </p>
      </div>

      <div class="space-y-4 text-sm">
        <div class="flex items-center gap-4">
          <span class="w-24 text-neutral-400 tracking-wide uppercase text-xs">El. paštas</span>
          <a href="mailto:dsuliauskaite@gmail.com" class="border-b border-neutral-400 pb-0.5 hover:text-neutral-500 transition-colors">
            dsuliauskaite@gmail.com
          </a>
        </div>
        <div class="flex items-center gap-4">
          <span class="w-24 text-neutral-400 tracking-wide uppercase text-xs">Instagram</span>
          <a href="https://www.instagram.com/ataik_nutrauksiu/" target="_blank" rel="noopener" class="border-b border-neutral-400 pb-0.5 hover:text-neutral-500 transition-colors">
            @ataik_nutrauksiu
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>
