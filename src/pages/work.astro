---
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import { series } from '../data/series';
import { getPhoto } from '../utils/photos';
---

<Layout title="Darbai — Deimantė Šuliauskaitė" description="Fotografijos portfolio — visi darbai ir projektai.">
  <section class="max-w-6xl mx-auto px-6 py-16">
    <h1 class="font-serif text-5xl italic font-medium tracking-tight mb-16">Darbai</h1>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
      {series.map(s => (
        <a href={`${import.meta.env.BASE_URL}work/${s.slug}`} class="group">
          <div class="aspect-[4/3] bg-rose-50 mb-4 overflow-hidden">
            <Image src={getPhoto(s.cover)} alt="" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" widths={[400, 600, 900]} sizes="(min-width: 1024px) 33vw, (min-width: 640px) 50vw, 100vw" quality={80} />
          </div>
          <h2 class="text-base font-medium group-hover:text-rose-500 transition-colors">{s.title}</h2>
          <p class="text-sm text-neutral-500 mt-1">{s.photos.length} nuotraukos</p>
        </a>
      ))}
    </div>
  </section>
</Layout>
