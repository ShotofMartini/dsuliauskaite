---
import Layout from '../layouts/Layout.astro';
import Photo from '../components/Photo.astro';
import { series as localSeries } from '../data/series';
import { hasSanity, getSeries } from '../lib/sanity';

const sanitySeries = hasSanity ? await getSeries() : null;

const series = sanitySeries
  ? sanitySeries.map((s) => ({ title: s.title, slug: s.slug.current, cover: s.cover, photos: s.photos }))
  : localSeries;
---

<Layout title="Darbai — vestuvių, krikštynų ir portretų fotografas Vilniuje" description="Portretų, vestuvių, krikštynų ir meninių fotosesijų portfolio. Fotografas Vilniuje ir visoje Lietuvoje.">
  <section class="max-w-6xl mx-auto px-6 py-16">
    <h1 class="font-serif text-5xl italic font-medium tracking-tight mb-16">Darbai</h1>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
      {series.map((s, i) => (
        <a href={`${import.meta.env.BASE_URL}work/${s.slug}`} class="group" data-animate style={`transition-delay: ${i * 75}ms`}>
          <div class="aspect-[4/3] bg-rose-50 mb-4 overflow-hidden">
            <Photo photo={s.cover} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" widths={[400, 600, 900]} sizes="(min-width: 1024px) 33vw, (min-width: 640px) 50vw, 100vw" />
          </div>
          <h2 class="text-base font-medium group-hover:text-rose-500 transition-colors">{s.title}</h2>
          <p class="text-sm text-neutral-500 mt-1">{s.photos.length} nuotraukos</p>
        </a>
      ))}
    </div>
  </section>
</Layout>
