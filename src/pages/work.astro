---
import Layout from '../layouts/Layout.astro';
import { series } from '../data/series';
---

<Layout title="Darbai — Deimantė Šuliauskaitė" description="Fotografijos portfolio — visi darbai ir projektai.">
  <section class="max-w-6xl mx-auto px-6 py-16">
    <h1 class="text-3xl font-light tracking-tight mb-16">Darbai</h1>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
      {series.map(s => (
        <a href={`/work/${s.slug}`} class="group">
          <div class="aspect-[4/3] bg-neutral-100 mb-4 overflow-hidden">
            <img src={`/images/${s.cover}.webp`} alt="" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" />
          </div>
          <h2 class="text-base font-medium group-hover:text-neutral-500 transition-colors">{s.title}</h2>
          <p class="text-sm text-neutral-500 mt-1">{s.photos.length} nuotraukos</p>
        </a>
      ))}
    </div>
  </section>
</Layout>
